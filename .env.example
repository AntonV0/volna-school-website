# Supabase public project settings. Keep real values in .env.local and Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Leave empty until a server-side admin task needs it.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only admin access allowlist. Comma-separate approved owner/admin emails.
ADMIN_ALLOWED_EMAILS=

# Public canonical site URL used for metadata, sitemap, and manifest output.
NEXT_PUBLIC_SITE_URL=https://www.volnaschool.com

# Analytics instrumentation. Vercel Analytics and Speed Insights need no ID.
# Keep marketing analytics false until consent wording and paid ads QA are approved.
NEXT_PUBLIC_ANALYTICS_DEBUG=false
NEXT_PUBLIC_ENABLE_MARKETING_ANALYTICS=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Registration spam protection. Keep the secret server-only.
# Leave empty locally or in early previews to keep the form fail-open while Turnstile is not configured.
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
