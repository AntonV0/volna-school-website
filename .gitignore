# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# source migration material for the existing business site
docs/source-screenshots/*
!docs/source-screenshots/.gitkeep
docs/source-copy/*
!docs/source-copy/.gitkeep
docs/site-audit/*
!docs/site-audit/.gitkeep
docs/assets/private/*
!docs/assets/private/.gitkeep
docs/assets/source/*
!docs/assets/source/.gitkeep

# raw originals should be reviewed before becoming public website assets
public/images/original/*
!public/images/original/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
